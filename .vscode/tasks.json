{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Next.js: Start Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/ui/fhir-place"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*> .*",
          "endsPattern": "^\\s*ready - started server on .+$"
        }
      }
    },
    {
      "label": "Next.js: Start Debug Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev:debug"],
      "options": {
        "cwd": "${workspaceFolder}/ui/fhir-place"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": {
          "regexp": "^([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*> .*",
          "endsPattern": "^\\s*ready - started server on .+$"
        }
      }
    },
    {
      "label": "Next.js: Build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/ui/fhir-place"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Next.js: Run Tests",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test"],
      "options": {
        "cwd": "${workspaceFolder}/ui/fhir-place"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Next.js: Watch Tests",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:watch"],
      "options": {
        "cwd": "${workspaceFolder}/ui/fhir-place"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "Launch Chrome Debug",
      "type": "shell",
      "command": "echo",
      "args": ["Launching Chrome for debugging..."],
      "dependsOrder": "sequence"
    },
    {
      "label": "Start FHIR Debug Container",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "compose.debug.yaml",
        "--profile",
        "debug",
        "up",
        "-d"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "dependsOn": "Build FHIR Debug Image"
    },
    {
      "label": "Build FHIR Debug Image",
      "type": "shell",
      "command": "docker",
      "args": [
        "build",
        "-f",
        "Dockerfile.debug",
        "-t",
        "ghcr.io/bbmri-cz/fhir-module:debug",
        "."
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
